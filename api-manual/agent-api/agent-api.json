          "results_limit": {"type": "integer", "minimum": 1, "default": 100, "description": "Maximum comments to collect per video URL."},
          "sort_by": {"type": "string", "enum": ["relevance", "newest"], "default": "newest"},
          "callback_url": {"type": "string", "format": "uri", "description": "Optional callback URL."}
