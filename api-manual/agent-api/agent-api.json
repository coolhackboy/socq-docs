          "sort_by": {"type": "string", "enum": ["relevance", "date", "likes"], "default": "relevance"},
          "published_within": {"type": "string", "enum": ["day", "week", "month", "three_months", "six_months"]},
          "callback_url": {"type": "string", "format": "uri", "description": "Optional callback URL."}
