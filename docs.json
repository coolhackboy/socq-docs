{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SocQ",
  "colors": {
    "primary": "#F64C31",
    "light": "#FF806B",
    "dark": "#C63A28"
  },
  "logo": {
    "light": "/assets/socq-logo-light.png",
    "dark": "/assets/socq-logo-dark.png",
    "href": "https://socq.ai"
  },
  "favicon": {
    "light": "/assets/socq-logo-light.png",
    "dark": "/assets/socq-logo-dark.png"
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Geist",
    "source": "/fonts/GeistVF.woff",
    "format": "woff",
    "weight": 400,
    "heading": {
      "family": "Geist",
      "source": "/fonts/GeistVF.woff",
      "format": "woff",
      "weight": 650
    },
    "body": {
      "family": "Geist",
      "source": "/fonts/GeistVF.woff",
      "format": "woff",
      "weight": 400
    }
  },
  "icons": {
    "library": "fontawesome"
  },
  "background": {
    "color": {
      "light": "#FCFAF8",
      "dark": "#090909"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "system"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://socq.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API key",
      "href": "https://socq.ai/dashboard/api-key"
    }
  },
  "api": {
    "baseUrl": "https://api.socq.ai",
    "auth": {
      "method": "bearer",
      "name": "Authorization",
      "inputPlaceholder": "YOUR_API_KEY"
    },
    "playground": {
      "mode": "simple"
    },
    "openapi": [
      "api-manual/agent-api/agent-api.json"
    ]
  },
  "redirects": [
    {
      "source": "/integrations/async-tasks",
      "destination": "/integrations/tasks-results"
    },
    {
      "source": "/integrations/pagination-files",
      "destination": "/integrations/tasks-results"
    },
    {
      "source": "/integrations/billing-limits",
      "destination": "/api-manual/agent-api/overview"
    },
    {
      "source": "/integrations/claude-code",
      "destination": "/integrations/claude-desktop"
    }
  ],
  "navigation": {
    "languages": [
      {
        "language": "en",
        "default": true,
        "navbar": {
          "links": [
            {
              "label": "Website",
              "href": "https://socq.ai"
            }
          ],
          "primary": {
