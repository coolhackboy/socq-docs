{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SocQ",
  "colors": {
    "primary": "#F64C31",
    "light": "#FF806B",
    "dark": "#C63A28"
  },
  "logo": {
    "light": "/assets/socq-logo-light.png",
    "dark": "/assets/socq-logo-dark.png",
    "href": "https://socqapi.ai"
  },
  "favicon": {
    "light": "/assets/socq-logo-light.png",
    "dark": "/assets/socq-logo-dark.png"
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Geist",
    "source": "/fonts/GeistVF.woff",
    "format": "woff",
    "weight": 400,
    "heading": {
      "family": "Geist",
      "source": "/fonts/GeistVF.woff",
      "format": "woff",
      "weight": 650
    },
    "body": {
      "family": "Geist",
      "source": "/fonts/GeistVF.woff",
      "format": "woff",
      "weight": 400
    }
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "color": {
      "light": "#FCFAF8",
      "dark": "#090909"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "system"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://socqapi.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API key",
      "href": "https://socqapi.ai/dashboard/api-key"
    }
  },
  "api": {
    "baseUrl": "https://api.socq.ai",
    "auth": {
      "method": "bearer",
      "name": "Authorization",
      "inputPlaceholder": "YOUR_API_KEY"
    },
    "playground": {
      "mode": "simple"
    },
    "openapi": [
      "api-manual/agent-api/agent-api.json"
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Agent API",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "api-manual/agent-api/overview"
            ]
          },
          {
            "group": "Instagram",
            "pages": [
              "api-manual/instagram/overview",
              "api-manual/instagram/posts",
              "api-manual/instagram/reels",
              "api-manual/instagram/search",
              "api-manual/instagram/followers-count"
            ]
          },
          {
            "group": "Facebook",
            "pages": [
              "api-manual/facebook/overview",
              "api-manual/facebook/pages",
              "api-manual/facebook/posts"
            ]
          },
          {
            "group": "Common",
            "pages": [
              "api-manual/agent-api/authentication",
              "api-manual/agent-api/status",
              "api-manual/agent-api/results",
              "api-manual/agent-api/files",
              "api-manual/agent-api/errors"
            ]
          }
        ]
      }
    ]
  }
}
