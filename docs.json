{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SocQ",
  "colors": {
    "primary": "#F64C31",
    "light": "#FF806B",
    "dark": "#C63A28"
  },
  "logo": {
    "light": "/assets/socq-logo-light.png",
    "dark": "/assets/socq-logo-dark.png",
    "href": "https://socq.ai"
  },
  "favicon": {
    "light": "/assets/socq-logo-light.png",
    "dark": "/assets/socq-logo-dark.png"
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Geist",
    "source": "/fonts/GeistVF.woff",
    "format": "woff",
    "weight": 400,
    "heading": {
      "family": "Geist",
      "source": "/fonts/GeistVF.woff",
      "format": "woff",
      "weight": 650
    },
    "body": {
      "family": "Geist",
      "source": "/fonts/GeistVF.woff",
      "format": "woff",
      "weight": 400
    }
  },
  "icons": {
    "library": "fontawesome"
  },
  "background": {
    "color": {
      "light": "#FCFAF8",
      "dark": "#090909"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "system"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://socq.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API key",
      "href": "https://socq.ai/dashboard/api-key"
    }
  },
  "api": {
    "baseUrl": "https://api.socq.ai",
    "auth": {
      "method": "bearer",
      "name": "Authorization",
      "inputPlaceholder": "YOUR_API_KEY"
    },
    "playground": {
      "mode": "simple"
    },
    "openapi": [
      "api-manual/agent-api/agent-api.json"
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "API",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "api-manual/agent-api/overview"
            ]
          },
          {
            "group": "Instagram",
            "pages": [
              "api-manual/instagram/overview",
              "api-manual/instagram/posts",
              "api-manual/instagram/comments",
              "api-manual/instagram/reels",
              "api-manual/instagram/search",
              "api-manual/instagram/followers-count"
            ]
          },
          {
            "group": "Facebook",
            "pages": [
              "api-manual/facebook/overview",
              "api-manual/facebook/pages",
              "api-manual/facebook/posts",
              "api-manual/facebook/comments"
            ]
          },
          {
            "group": "Facebook Marketplace",
            "pages": [
              "api-manual/facebook-marketplace/overview",
              "api-manual/facebook-marketplace/location-search",
              "api-manual/facebook-marketplace/search",
              "api-manual/facebook-marketplace/item"
            ]
          },
          {
            "group": "Facebook Ad Library",
            "pages": [
              "api-manual/facebook-ad-library/overview",
              "api-manual/facebook-ad-library/search",
              "api-manual/facebook-ad-library/company-search",
              "api-manual/facebook-ad-library/company-ads",
              "api-manual/facebook-ad-library/ad"
            ]
          },
          {
            "group": "YouTube",
            "pages": [
              "api-manual/youtube/overview",
              "api-manual/youtube/channels",
              "api-manual/youtube/videos",
              "api-manual/youtube/channel-videos",
              "api-manual/youtube/comments",
              "api-manual/youtube/shorts",
              "api-manual/youtube/search",
              "api-manual/youtube/transcripts"
            ]
          },
          {
            "group": "TikTok",
            "pages": [
              "api-manual/tiktok/overview",
              "api-manual/tiktok/profiles",
              "api-manual/tiktok/videos",
              "api-manual/tiktok/comments",
              "api-manual/tiktok/search",
              "api-manual/tiktok/hashtags"
            ]
          },
          {
            "group": "TikTok Shop",
            "pages": [
              "api-manual/tiktok-shop/overview",
              "api-manual/tiktok-shop/search",
              "api-manual/tiktok-shop/products",
              "api-manual/tiktok-shop/product",
              "api-manual/tiktok-shop/product-reviews",
              "api-manual/tiktok-shop/user-showcase"
            ]
          },
          {
            "group": "X",
            "pages": [
              "api-manual/x/overview",
              "api-manual/x/profiles",
              "api-manual/x/posts",
              "api-manual/x/user-posts",
              "api-manual/x/search"
            ]
          },
          {
            "group": "LinkedIn",
            "pages": [
              "api-manual/linkedin/overview",
              "api-manual/linkedin/profiles",
              "api-manual/linkedin/companies",
              "api-manual/linkedin/posts",
              "api-manual/linkedin/jobs"
            ]
          },
          {
            "group": "Reddit",
            "pages": [
              "api-manual/reddit/overview",
              "api-manual/reddit/posts",
              "api-manual/reddit/comments",
              "api-manual/reddit/subreddit-posts",
              "api-manual/reddit/search"
            ]
          },
          {
            "group": "Pinterest",
            "pages": [
              "api-manual/pinterest/overview",
              "api-manual/pinterest/profiles",
              "api-manual/pinterest/pins",
              "api-manual/pinterest/user-pins",
              "api-manual/pinterest/search"
            ]
          },
          {
            "group": "Threads",
            "pages": [
              "api-manual/threads/overview",
              "api-manual/threads/profiles",
              "api-manual/threads/posts",
              "api-manual/threads/user-posts"
            ]
          },
          {
            "group": "Common",
            "pages": [
              "api-manual/agent-api/authentication",
              "api-manual/agent-api/callbacks",
              "api-manual/agent-api/status",
              "api-manual/agent-api/files",
              "api-manual/agent-api/errors"
            ]
          }
        ]
      }
    ]
  }
}
